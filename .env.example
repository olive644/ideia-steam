# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Cloudflare Turnstile (proteção contra bots no cadastro)
# Obtenha em: https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAD3UU2hkTdR49byD
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Secrets das Edge Functions (configurar via `supabase secrets set`, não aqui)
# Exemplo: supabase secrets set IGDB_CLIENT_ID=xxx IGDB_CLIENT_SECRET=yyy STEAM_API_KEY=zzz TURNSTILE_SECRET_KEY=aaa
# IGDB_CLIENT_ID=
# IGDB_CLIENT_SECRET=
# STEAM_API_KEY=
# TURNSTILE_SECRET_KEY=
